<Window x:Class="ZarzadzanieWydatkami.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ZarzadzanieWydatkami.Client"
        Title="Zarządzanie Wydatkami - Dashboard" Height="550" Width="950">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Pobierz" Command="{Binding PobierzWydatkiCommand}" Margin="5" Padding="10,5" />
            <Button Content="Dodaj nowy" Command="{Binding DodajWydatekCommand}" Margin="5" Padding="10,5"/>
            <Button Content="Usuń Wybrane" Command="{Binding UsunWydatekCommand}" Margin="5" Padding="10,5" Background="#FFDDDD" Foreground="DarkRed" FontWeight="Bold"/>
            <Button Content="Cofnij Usunięcie" Command="{Binding CofnijUsuniecieCommand}" IsEnabled="{Binding CzyMoznaCofnac}" Margin="5" Padding="10,5" Background="#DDFFDD" Foreground="DarkGreen" FontWeight="Bold"/>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="15,0" />

            <TextBox Text="{Binding NowaKategoriaTekst, UpdateSourceTrigger=PropertyChanged}" Width="100" Margin="5" VerticalAlignment="Center" Padding="5"/>
            <Button Content="Dodaj Kategorię" Command="{Binding DodajKategorieCommand}" Margin="5" Padding="10,5"/>
        </StackPanel>

        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Wydatki}" 
                  SelectedItem="{Binding WybranyWydatek}" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  RowEditEnding="DataGrid_RowEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="40"/>
                <DataGridTextColumn Header="Tytuł" Binding="{Binding Tytul, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Kwota (PLN)" Binding="{Binding Kwota, StringFormat=\{0:N2\}, UpdateSourceTrigger=LostFocus}" Width="100"/>

                <DataGridTemplateColumn Header="Kategoria" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Kategoria}" Padding="4" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding Kategoria, UpdateSourceTrigger=PropertyChanged}" 
                                      ItemsSource="{Binding DataContext.Kategorie, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Data" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Data, StringFormat=\{0:dd.MM.yyyy\}}" Padding="4" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <DatePicker SelectedDate="{Binding Data, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#FFF3F3F3" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Margin="0,10,0,0" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Budżet miesięczny: " FontSize="16" Foreground="Gray"/>
                    <TextBox KeyDown="BudzetTextBox_KeyDown" Text="{Binding BudzetMiesieczny, StringFormat=\{0:N2\}, UpdateSourceTrigger=LostFocus}" FontSize="16" FontWeight="Bold" Width="80" TextAlignment="Right" Background="Transparent" BorderThickness="0,0,0,1"/>
                    <TextBlock Text=" zł" FontSize="16" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Wydano w tym miesiącu: " FontSize="16" Foreground="Gray"/>
                    <TextBlock Text="{Binding SumaWydatkow, StringFormat=\{0:N2\}}" FontSize="16" FontWeight="Bold" Foreground="DarkRed"/>
                    <TextBlock Text=" zł" FontSize="16" FontWeight="Bold" Foreground="DarkRed"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Pozostało: " FontSize="16" Foreground="Gray"/>
                    <TextBlock Text="{Binding PozostaloZBudzetu, StringFormat=\{0:N2\}}" FontSize="16" FontWeight="Bold" Foreground="DarkGreen"/>
                    <TextBlock Text=" zł" FontSize="16" FontWeight="Bold" Foreground="DarkGreen"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>